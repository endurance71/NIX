{
  "name": "nix",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "expo lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check-knip": "knip --exclude exports,types,enumMembers,nsExports,nsTypes,namespaceMembers,duplicates --no-config-hints",
    "react-doctor": "npx -y react-doctor@latest . --verbose",
    "react-doctor:score": "npx -y react-doctor@latest . --score",
    "react-doctor:diff": "npx -y react-doctor@latest . --verbose --diff",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/material-symbols": "^0.4.38",
    "@expo/material-symbols": "^0.1.1",
    "@expo/ui": "~56.0.18",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.7",
    "base64-js": "^1.5.1",
    "expo": "^56.0.12",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-background-fetch": "~56.0.19",
    "expo-blur": "~56.0.3",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.11",
    "expo-screen-capture": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "expo-video": "~56.1.4",
    "graphemer": "^1.4.0",
    "i18next": "^26.0.10",
    "mime-db": "^1.54.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.7",
    "react-native": "0.85.3",
    "react-native-compressor": "^1.18.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-pretty-toast": "^1.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.8.3",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.5",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "knip": "^6.12.2",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "private": true,
  "allowScripts": {
    "@sentry/cli@2.58.4": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.11.1": true
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-compressor"
        ]
      }
    }
  }
}
