{
  "name": "nix",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "lint": "expo lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check-knip": "knip --exclude exports,types,enumMembers,nsExports,nsTypes,namespaceMembers,duplicates --no-config-hints",
    "expo-doctor": "npx -y expo-doctor@latest",
    "expo-install-check": "expo install --check",
    "export:production": "SENTRY_DISABLE_AUTO_UPLOAD=true SENTRY_DISABLE_XCODE_DEBUG_UPLOAD=true expo export --platform ios --output-dir dist",
    "check:ios-config": "node scripts/check-ios-config.mjs",
    "check:sentry-disabled": "node scripts/check-sentry-disabled.mjs",
    "check:supabase-migrations": "node scripts/check-supabase-migrations.mjs",
    "check:supabase-db-lint": "node scripts/check-supabase-db-lint.mjs",
    "check:internal-testflight-config": "node scripts/check-internal-testflight-config.mjs",
    "deno:check": "npx -y deno check --lock=deno.lock supabase/functions/_shared/http.ts supabase/functions/_shared/service-auth.ts supabase/functions/_shared/push.ts supabase/functions/cleanup-nix/index.ts supabase/functions/delete-account/index.ts supabase/functions/report-content/index.ts supabase/functions/block-user/index.ts supabase/functions/moderation-admin/index.ts supabase/functions/cleanup-moderation-evidence/index.ts supabase/functions/push-dispatch/index.ts supabase/functions/push-receipts/index.ts",
    "deno:test": "npx -y deno test --lock=deno.lock supabase/functions/_shared/http_test.ts supabase/functions/_shared/service-auth_test.ts",
    "doctor:react": "react-doctor . --verbose",
    "doctor:react:ci": "react-doctor . --verbose --blocking warning --no-score",
    "doctor:react:score": "react-doctor . --score",
    "doctor:react:changed": "react-doctor . --verbose --scope changed --include-untracked",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.1",
    "expo": "~57.0.8",
    "expo-apple-authentication": "~57.0.1",
    "expo-asset": "~57.0.3",
    "expo-audio": "~57.0.3",
    "expo-blur": "~57.0.2",
    "expo-build-properties": "~57.0.7",
    "expo-camera": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.9",
    "expo-file-system": "~57.0.0",
    "expo-glass-effect": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.6",
    "expo-image-picker": "~57.0.6",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-localization": "~57.0.1",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-screen-capture": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-store-review": "~57.0.1",
    "expo-updates": "~57.0.10",
    "expo-video": "~57.0.2",
    "graphemer": "^1.4.0",
    "i18next": "^26.3.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-compressor": "^1.18.1",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-image-crop-picker": "^0.51.1",
    "react-native-pretty-toast": "^1.0.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.10.0",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.5",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "expo-mcp": "^0.2.4",
    "knip": "^6.18.0",
    "patch-package": "^8.0.1",
    "react-doctor": "0.7.8",
    "sf-symbols-typescript": "^2.2.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "private": true,
  "overrides": {
    "uuid": "^11.1.1"
  },
  "patch-package": {
    "ignorePaths": [
      "**/.DS_Store"
    ]
  },
  "allowScripts": {
    "@sentry/cli@2.58.4": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.12.2": true
  },
  "expo": {
    "autolinking": {
      "ios": {
        "buildFromSource": [
          "expo-camera",
          "expo-image-manipulator"
        ]
      }
    },
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-compressor"
        ]
      }
    }
  }
}
