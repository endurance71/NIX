{
  "expo": {
    "name": "NiX",
    "slug": "nix-app",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./nix-icons/icon.png",
    "userInterfaceStyle": "automatic",
    "web": {
      "favicon": "./nix-icons/favicon.png"
    },
    "android": {
      "package": "com.damianmotylinski.nixapp",
      "adaptiveIcon": {
        "foregroundImage": "./nix-icons/icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.damianmotylinski.nixapp",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "NiX potrzebuje dostępu do kamery, aby przechwytywać i wysyłać wiadomości.",
        "NSMicrophoneUsageDescription": "NiX potrzebuje dostępu do mikrofonu, aby nagrywać wiadomości wideo.",
        "NSPhotoLibraryUsageDescription": "NiX potrzebuje dostępu do zdjęć i filmów, aby korzystać z multimediów.",
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "scheme": "nix",
    "plugins": [
      "expo-localization",
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NiX potrzebuje dostępu do kamery, aby przechwytywać i wysyłać wiadomości.",
          "microphonePermission": "NiX potrzebuje dostępu do mikrofonu, aby nagrywać wiadomości wideo."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NiX potrzebuje dostępu do zdjęć, aby ustawić awatar profilu."
        }
      ],
      "expo-video",
      "expo-secure-store",
      "react-native-compressor",
      "expo-image",
      "expo-audio",
      "expo-asset",
      "expo-status-bar",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./nix-icons/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "enableBsdiffPatchSupport": true
    },
    "locales": {
      "en": "./src/locales/en/common.json",
      "pl": "./src/locales/pl/common.json"
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "c7ada746-56ff-4e91-827c-8ec2686650b8"
      }
    },
    "owner": "mt_hub"
  }
}
