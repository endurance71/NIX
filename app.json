{
  "expo": {
    "name": "NiX",
    "slug": "nix-app",
    "version": "1.0.0",
    "platforms": [
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./assets/brand/app/ios-light.png",
    "userInterfaceStyle": "automatic",
    "web": {
      "favicon": "./assets/brand/web/favicon-48.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.damianmotylinski.nixapp",
      "icon": {
        "light": "./assets/brand/app/ios-light.png",
        "dark": "./assets/brand/app/ios-dark.png",
        "tinted": "./assets/brand/app/ios-tinted.png"
      },
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "NiX potrzebuje dostępu do kamery, aby przechwytywać i wysyłać wiadomości.",
        "NSMicrophoneUsageDescription": "NiX potrzebuje dostępu do mikrofonu, aby nagrywać wiadomości wideo.",
        "NSPhotoLibraryUsageDescription": "NiX potrzebuje dostępu do zdjęć i filmów, aby korzystać z multimediów.",
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "scheme": "nix",
    "plugins": [
      "expo-localization",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "AppCheckCore",
                "version": "11.2.0"
              }
            ]
          }
        }
      ],
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NiX potrzebuje dostępu do kamery, aby przechwytywać i wysyłać wiadomości.",
          "microphonePermission": "NiX potrzebuje dostępu do mikrofonu, aby nagrywać wiadomości wideo."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NiX potrzebuje dostępu do zdjęć, aby ustawić awatar profilu."
        }
      ],
      "expo-video",
      "expo-secure-store",
      "react-native-compressor",
      "expo-image",
      "expo-audio",
      "expo-asset",
      "expo-status-bar",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash/splash-mark.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "@react-native-google-signin/google-signin",
      "./plugins/withIosXcodeSpacesInPathFix.js",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "enableBsdiffPatchSupport": true
    },
    "locales": {
      "en": "./src/locales/en/common.json",
      "pl": "./src/locales/pl/common.json"
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "c7ada746-56ff-4e91-827c-8ec2686650b8"
      }
    },
    "owner": "mt_hub"
  }
}
