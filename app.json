{
  "expo": {
    "name": "NiX",
    "slug": "nix-app",
    "version": "1.0.2",
    "platforms": [
      "ios"
    ],
    "orientation": "portrait",
    "icon": "./assets/brand/app/ios-light.png",
    "userInterfaceStyle": "automatic",
    "web": {
      "favicon": "./assets/brand/web/favicon-48.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.damianmotylinski.nixapp",
      "icon": {
        "light": "./assets/brand/app/ios-light.png",
        "dark": "./assets/brand/app/ios-dark.png",
        "tinted": "./assets/brand/app/ios-tinted.png"
      },
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "NiX uses the camera to take photos and videos that you choose to send to friends.",
        "NSMicrophoneUsageDescription": "NiX uses the microphone to record sound in video messages that you choose to send.",
        "NSPhotoLibraryUsageDescription": "NiX uses your photo library when you choose a profile avatar or select a photo or video to send to friends.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIViewControllerBasedStatusBarAppearance": false,
        "CADisableMinimumFrameDurationOnPhone": true
      }
    },
    "scheme": "nix",
    "plugins": [
      "expo-localization",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              {
                "name": "AppCheckCore",
                "version": "11.2.0"
              }
            ]
          }
        }
      ],
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NiX uses the camera to take photos and videos that you choose to send to friends.",
          "microphonePermission": "NiX uses the microphone to record sound in video messages that you choose to send."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NiX uses your photo library when you choose a profile avatar or select a photo or video to send to friends."
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      "expo-secure-store",
      "react-native-compressor",
      "expo-image",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-asset",
      "expo-status-bar",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash/splash-mark.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "@react-native-google-signin/google-signin",
      "./plugins/withIosXcodeSpacesInPathFix.js",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "enableBsdiffPatchSupport": true,
      "url": "https://u.expo.dev/c7ada746-56ff-4e91-827c-8ec2686650b8"
    },
    "runtimeVersion": "1.0.2",
    "locales": {
      "en": "./src/locales/en/common.json",
      "pl": "./src/locales/pl/common.json"
    },
    "extra": {
      "router": {
        "root": "./src/app"
      },
      "eas": {
        "projectId": "c7ada746-56ff-4e91-827c-8ec2686650b8"
      }
    },
    "owner": "mt_hub"
  }
}
