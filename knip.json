{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/app/_layout.tsx", "src/services/videoCompressionService.ts"],
  "project": ["src/**/*.{ts,tsx}", "vitest-shims/**/*.ts"],
  "ignore": [
    "**/*.test.ts",
    "src/types/database.types.ts",
    "vitest-shims/**",
    "supabase/functions/**",
    "src/components/friend/incoming-requests-list.tsx"
